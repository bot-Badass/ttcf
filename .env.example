# ── Telegram ─────────────────────────────────────────────────────────────────
# Токен бота (BotFather) та chat_id оператора
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLLING_INTERVAL_SECONDS=5

# ── Субтитри ─────────────────────────────────────────────────────────────────
# Режим вирівнювання: whisperx_or_fallback | fallback
SUBTITLE_ALIGNMENT_MODE=fallback
WHISPERX_MODEL_SIZE=small
WHISPERX_DEVICE=cpu
WHISPERX_COMPUTE_TYPE=int8
SUBTITLE_MAX_WORDS_PER_PHRASE=6
SUBTITLE_MAX_CHARS_PER_PHRASE=42
SUBTITLE_MAX_SILENCE_GAP_SECONDS=0.5

# Стиль субтитрів (ASS)
SUBTITLE_FONT_NAME=Arial
SUBTITLE_FONT_SIZE=26
SUBTITLE_PRIMARY_COLOR=&H00FFFFFF
SUBTITLE_OUTLINE_COLOR=&H00000000
SUBTITLE_BACK_COLOR=&H80000000
SUBTITLE_BOLD=1
SUBTITLE_OUTLINE_WIDTH=2
SUBTITLE_SHADOW_DEPTH=0
SUBTITLE_ALIGNMENT=5
SUBTITLE_MARGIN_V=0
SUBTITLE_BORDER_STYLE=3

# ── ffmpeg ────────────────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_BIN=ffprobe
FFPROBE_TIMEOUT_SECONDS=30
FFMPEG_TIMEOUT_SECONDS=600

# ── Pexels ────────────────────────────────────────────────────────────────────
# Безкоштовний ключ: https://www.pexels.com/api/
PEXELS_API_KEY=
ADVICE_PEXELS_QUERY=ukraine city night
ADVICE_PEXELS_VIDEO_MIN_DURATION=15

# Локальне відео-тло (якщо не порожньо — Pexels не використовується)
ADVICE_LOCAL_BACKGROUND_VIDEO=
BACKGROUND_VIDEO_PATH=

# ── Голосовий pipeline (Respeecher) ──────────────────────────────────────────
# Ключ API та ID голосу за замовчуванням
RESPEECHER_API_KEY=
RESPEECHER_DEFAULT_VOICE_ID=

# Режим голосу: true = оператор записує голосові повідомлення через Telegram
#               false = Piper TTS (локальна генерація)
VOICE_MODE=true

# Шлях до файлу сесій голосу (за замовчуванням: data/manifests/voice_sessions.json)
# VOICE_SESSION_STORE_PATH=data/manifests/voice_sessions.json

# ── Мікросерійний контент ─────────────────────────────────────────────────────
# Мін./макс. кількість частин у серії
ADVICE_MICRO_SERIES_MIN_PARTS=3
ADVICE_MICRO_SERIES_MAX_PARTS=5

# Мінімальна кількість слів у скрипті
ADVICE_SCRIPT_MIN_WORDS=100

# TTS голос Piper (якщо VOICE_MODE=false)
ADVICE_TTS_VOICE=dmytro
ADVICE_PIPER_MODEL=

# Hook-кадр — статична заставка перед кожним відео
HOOK_FRAME_ENABLED=true
HOOK_FRAME_DURATION=2.0
HOOK_FRAME_FONT_SIZE=52
HOOK_FRAME_BG_COLOR=0x0a0a0a
HOOK_FRAME_TEXT_COLOR=white
HOOK_FRAME_ACCENT_COLOR=0xFF3B30
# Шлях до .ttf файлу (порожньо = ffmpeg-шрифт за замовчуванням)
HOOK_FRAME_FONT_FILE=

# ── Reddit intake (необов'язково) ─────────────────────────────────────────────
DEEPL_API_KEY=
DEEPL_SERVER_URL=https://api-free.deepl.com
DEEPL_MAX_CHARS_PER_REQUEST=50000
DEEPL_MAX_RETRIES=3
DEEPL_RETRY_BASE_DELAY_SECONDS=0.5

# ── Системне (macOS / PyTorch) ────────────────────────────────────────────────
# Усуває попередження про дублювання MKL на macOS
KMP_DUPLICATE_LIB_OK=TRUE
